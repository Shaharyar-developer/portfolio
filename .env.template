# Shaharyar Labs / SheetDue environment template
# Copy these keys into your real local/deployment environment and replace placeholders.
# Do not commit real secrets.

# ---------------------------------------------------------------------------
# Docker services
# ---------------------------------------------------------------------------

# Used by docker-compose.yml for local development Postgres.
POSTGRES_USER="labs"
POSTGRES_PASSWORD="labs_dev_password"
POSTGRES_DB="labs"
POSTGRES_PORT="5432"

# Adminer database UI port.
# Open http://localhost:8080 after docker compose up -d.
ADMINER_PORT="8080"

# ---------------------------------------------------------------------------
# App URLs
# ---------------------------------------------------------------------------

# Public base URL for the labs app.
# Local: http://localhost:3001
# Production: https://labs.shaharyar.dev
LABS_BASE_URL="http://localhost:3001"

# Browser-visible labs URL used by the Better Auth client.
# Usually the same value as LABS_BASE_URL.
NEXT_PUBLIC_LABS_BASE_URL="http://localhost:3001"

# Optional cookie domain for sharing auth across labs subdomains.
# Production default should be .labs.shaharyar.dev if future apps use subdomains.
# Leave blank for localhost.
AUTH_COOKIE_DOMAIN=

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# Neon/Vercel Postgres connection string used by Drizzle and Better Auth.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/labs?sslmode=require"

# ---------------------------------------------------------------------------
# Better Auth
# ---------------------------------------------------------------------------

# Generate a strong secret for production.
# Example: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# ---------------------------------------------------------------------------
# Google OAuth, Google Picker, Sheets, and Drive
# ---------------------------------------------------------------------------

# OAuth client used for both Better Auth Google sign-in and SheetDue's
# app-specific Google Sheets connection flow.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Register this exact URI in Google Cloud Console:
# APIs & Services -> Credentials -> OAuth 2.0 Client -> Authorized redirect URIs.
# Local default: http://localhost:3001/api/google/oauth/callback
# Production default: https://labs.shaharyar.dev/api/google/oauth/callback
# Set explicitly if you use a tunnel, alternate local port, or preview domain.
GOOGLE_SHEETDUE_REDIRECT_URI="http://localhost:3001/api/google/oauth/callback"

# Google Picker browser API key.
GOOGLE_PICKER_API_KEY=""

# 32-byte key for encrypting stored Google access/refresh tokens.
# Use either 64 hex characters or base64 that decodes to exactly 32 bytes.
# Example: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=""

# ---------------------------------------------------------------------------
# Polar billing
# ---------------------------------------------------------------------------

# Polar access token for checkout and customer portal routes.
POLAR_ACCESS_TOKEN=""

# Webhook secret from Polar for /api/webhooks/polar.
POLAR_WEBHOOK_SECRET=""

# Polar product ID for the SheetDue Pro product.
POLAR_SHEETDUE_PRODUCT_ID=""

# Use "sandbox" while testing. Omit or set "production" in production.
POLAR_SERVER="sandbox"

# ---------------------------------------------------------------------------
# Plunk email delivery
# ---------------------------------------------------------------------------

# Plunk secret key used to send transactional reminder emails.
PLUNK_SECRET_KEY=""

# Hosted Plunk default is https://next-api.useplunk.com.
# Set this if using a self-hosted Plunk instance.
PLUNK_API_BASE_URL="https://next-api.useplunk.com"

# Verified sender email/domain in Plunk.
PLUNK_FROM_EMAIL="reminders@labs.shaharyar.dev"

# Optional shared secret expected by /api/webhooks/plunk.
# Leave blank to accept Plunk webhook payloads without bearer-token checking.
PLUNK_WEBHOOK_SECRET=""

# ---------------------------------------------------------------------------
# Cron
# ---------------------------------------------------------------------------

# Bearer token required by /api/cron/sheetdue.
# Vercel Cron should send: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=""

# ---------------------------------------------------------------------------
# Deployment
# ---------------------------------------------------------------------------

# Vercel sets this automatically. Keep blank locally.
# In production, missing BETTER_AUTH_SECRET or Google OAuth credentials will fail fast.
VERCEL_ENV=""

# Managed by Next.js/Node. Do not set this manually unless you know you need to.
# Expected values are development, test, or production.
NODE_ENV=""
